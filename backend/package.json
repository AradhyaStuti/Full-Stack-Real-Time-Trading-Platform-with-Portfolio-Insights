{
  "name": "trading-platform-api",
  "version": "1.0.0",
  "description": "Real-time trading platform REST API",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "cross-env NODE_ENV=test jest --runInBand --forceExit --detectOpenHandles",
    "test:coverage": "cross-env NODE_ENV=test jest --runInBand --forceExit --detectOpenHandles --coverage",
    "test:watch": "cross-env NODE_ENV=test jest --runInBand --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": ["./tests/setup.js"],
    "testMatch": ["**/tests/**/*.test.js"],
    "coverageDirectory": "coverage",
    "coveragePathIgnorePatterns": ["/node_modules/", "/tests/"],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "joi": "^18.1.1",
    "mongoose": "^8.2.1",
    "morgan": "^1.10.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "passport-local-mongoose": "^8.0.0",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0"
  }
}
